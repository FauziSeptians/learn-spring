# Set default behavior to automatically normalize line endings.
* text=auto

# Force LF for shell scripts and gradlew/mvnw
mvnw text eol=lf
*.sh text eol=lf

# Force CRLF for batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
